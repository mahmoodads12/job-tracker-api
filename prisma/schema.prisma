
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  jobs JobApplication[]
}

model JobApplication {
  id        String   @id @default(uuid())
  title     String
  company   String
  status    String
  notes     String?
  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id])
}